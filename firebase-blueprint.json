{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information and social status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "bio": { "type": "string" },
        "gender": { "type": "string" },
        "age": { "type": "number" },
        "profilePic": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline"] },
        "lastSeen": { "type": "string", "format": "date-time" },
        "isTypingIn": { "type": "string", "description": "Chat ID where user is typing" }
      },
      "required": ["uid", "displayName"]
    },
    "Chat": {
      "title": "Chat Session",
      "description": "A conversation between users or a group",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["individual", "group"] },
        "participants": { "type": "array", "items": { "type": "string" } },
        "name": { "type": "string", "description": "Group name" },
        "description": { "type": "string" },
        "lastMessage": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "participants"]
    },
    "Message": {
      "title": "Message",
      "description": "A message sent in a chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "file", "gif", "emoji"] },
        "fileUrl": { "type": "string" },
        "fileName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "seenBy": { "type": "array", "items": { "type": "string" } },
        "savedBy": { "type": "array", "items": { "type": "string" }, "description": "Users who saved this chat bubble" }
      },
      "required": ["chatId", "senderId", "content", "timestamp"]
    },
    "FriendRequest": {
      "title": "Friend Request",
      "description": "Request to be friends",
      "type": "object",
      "properties": {
        "fromId": { "type": "string" },
        "fromName": { "type": "string" },
        "fromPic": { "type": "string" },
        "toId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected", "cancelled"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat sessions"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat"
    },
    "/friendRequests/{requestId}": {
      "schema": "FriendRequest",
      "description": "Friend request management"
    }
  }
}
