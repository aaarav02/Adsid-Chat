rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PHASE 3: Primitive Definitions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      // Relaxing email verification for development/sandboxed environment
      return isSignedIn();
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'extremear762@gmail.com';
    }

    function isOwner(userId) {
      return isVerified() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- PHASE 4: Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName']) &&
             data.uid == request.auth.uid &&
             data.uid is string && data.uid.size() <= 128 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 500)) &&
             (!('gender' in data) || (data.gender is string && data.gender.size() <= 20)) &&
             (!('age' in data) || (data.age is number && data.age >= 0 && data.age <= 150)) &&
             (!('status' in data) || data.status in ['online', 'offline']) &&
             (!('profilePic' in data) || (data.profilePic is string && data.profilePic.size() <= 1000)) &&
             (!('lastSeen' in data) || (data.lastSeen is timestamp)) &&
             (!('isRegistered' in data) || (data.isRegistered is bool)) &&
             (!('isTypingIn' in data) || (data.isTypingIn is string || data.isTypingIn == null));
    }

    function isValidChat(data) {
      return data.keys().hasAll(['type', 'participants']) &&
             data.type in ['individual', 'group'] &&
             data.participants is list &&
             data.participants.size() >= 1 && data.participants.size() <= 100 &&
             (request.auth.uid in data.participants || isAdmin()) &&
             (!('disappearingMode' in data) || data.disappearingMode is bool);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['chatId', 'senderId', 'content', 'timestamp']) &&
             data.chatId is string && data.chatId.size() <= 128 &&
             data.senderId == request.auth.uid &&
             data.content is string && data.content.size() <= 10000 &&
             data.timestamp == request.time &&
             (!('senderName' in data) || (data.senderName is string && data.senderName.size() <= 100)) &&
             (!('type' in data) || (data.type in ['text', 'image', 'gif', 'file'])) &&
             (!('mediaUrl' in data) || (data.mediaUrl is string && data.mediaUrl.size() <= 1000000) || data.mediaUrl == null) &&
             (!('savedBy' in data) || (data.savedBy is list && data.savedBy.size() <= 100)) &&
             (!('seenBy' in data) || (data.seenBy is list && data.seenBy.size() <= 100));
    }

    function isValidFriendRequest(data) {
      return data.keys().hasAll(['fromId', 'toId', 'status', 'timestamp']) &&
             data.fromId == request.auth.uid &&
             data.status == 'pending' &&
             data.timestamp == request.time &&
             (!('fromName' in data) || (data.fromName is string && data.fromName.size() <= 100)) &&
             (!('fromPic' in data) || (data.fromPic is string && data.fromPic.size() <= 1000));
    }

    // --- PHASE 5: Implementation (The Fortress) ---

    // Connection test document
    match /test/connection {
      allow read: if true;
    }

    // Users collection
    match /users/{userId} {
      allow get: if isValidId(userId) && isVerified();
      allow list: if isVerified();
      allow create: if isValidId(userId) && isOwner(userId) && isValidUser(incoming());
      allow update: if isValidId(userId) && isOwner(userId) && isValidUser(incoming());

      // Friends subcollection
      match /friends/{friendId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Friend Requests
    match /friendRequests/{requestId} {
      allow get: if isValidId(requestId) && isVerified() && (existing().fromId == request.auth.uid || existing().toId == request.auth.uid);
      allow list: if isVerified() && (existing().fromId == request.auth.uid || existing().toId == request.auth.uid || isAdmin());
      allow create: if isVerified() && isValidId(requestId) && isValidFriendRequest(incoming()) &&
                    exists(/databases/$(database)/documents/users/$(incoming().toId));
      allow update: if isVerified() && isValidId(requestId) && (
        // Action: Accept/Reject
        (existing().toId == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
         incoming().status in ['accepted', 'rejected']) ||
        // Action: Cancel
        (existing().fromId == request.auth.uid &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
         incoming().status == 'cancelled')
      );
      allow delete: if isVerified() && (existing().fromId == request.auth.uid || existing().toId == request.auth.uid || isAdmin());
    }

    // Chats
    match /chats/{chatId} {
      function isParticipant() {
        return isVerified() && (request.auth.uid in existing().participants || isAdmin());
      }

      allow get: if isValidId(chatId) && isParticipant();
      allow list: if isParticipant() || isAdmin();
      allow create: if isVerified() && isValidId(chatId) && isValidChat(incoming());
      allow update: if isValidId(chatId) && (isParticipant() || isAdmin()) && (
        // Allow updating lastMessage, disappearingMode, and metadata
        incoming().diff(existing()).affectedKeys().hasAny(['lastMessage', 'disappearingMode', 'name', 'description', 'participants']) && (
           // Ensure it is still a valid chat state
           isValidChat(incoming())
        )
      );
      allow delete: if isValidId(chatId) && (isParticipant() || isAdmin());

      // Messages subcollection
      match /messages/{messageId} {
        function canInteractWithChat() {
          return isVerified() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isAdmin());
        }

        allow get: if isValidId(chatId) && isValidId(messageId) && canInteractWithChat();
        allow list: if isValidId(chatId) && canInteractWithChat();
        allow create: if isValidId(chatId) && isValidId(messageId) && canInteractWithChat() && isValidMessage(incoming());
        allow update: if isValidId(chatId) && isValidId(messageId) && canInteractWithChat() && (
          // Action: Save/Seen toggle
          (incoming().diff(existing()).affectedKeys().hasAny(['savedBy', 'seenBy']) &&
           incoming().diff(existing()).affectedKeys().hasOnly(['savedBy', 'seenBy']))
           ||
           // Action: Full sender update
           (existing().senderId == request.auth.uid && isValidMessage(incoming()) &&
            incoming().diff(existing()).affectedKeys().hasOnly(['content', 'timestamp', 'savedBy', 'seenBy', 'type', 'fileName', 'fileUrl']))
        );
        allow delete: if isVerified() && isValidId(chatId) && isValidId(messageId) && (
          existing().senderId == request.auth.uid || isAdmin()
        );
      }
    }
  }
}
